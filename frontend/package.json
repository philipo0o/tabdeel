{
  "name": "tabdeel-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "build:static": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "optimize-images": "node scripts/optimize-images.js",
    "docker:build": "docker build -t tabdeel-frontend .",
    "docker:run": "docker run -p 3002:3002 tabdeel-frontend",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker-compose up --build",
    "docker:stop": "docker-compose down"
  },
  "dependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "axios": "^1.6.2",
    "mammoth": "^1.12.0",
    "next": "^15.1.0",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "sharp": "^0.34.5"
  }
}
